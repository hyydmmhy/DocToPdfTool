<Window x:Class="DocToPdfTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DocToPdfTool - 文档转换工具"
        Width="800"
        Height="500"
        MinWidth="680"
        MinHeight="400"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- 左侧导航 -->
        <Border DockPanel.Dock="Left" Width="180" Background="#FAFAFA"
                BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel>
                <Border Padding="16,16,16,12" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <TextBlock Text="功能导航" Foreground="#888888" FontSize="12"/>
                </Border>
                <ListBox x:Name="NavList" Style="{StaticResource NavListBox}"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBoxItem Tag="DocToPdf" Content="文档转PDF" FontSize="14"/>
                    <ListBoxItem Tag="WordToPdf" Content="Word转PDF" FontSize="14"/>
                    <ListBoxItem Tag="PdfToWord" Content="PDF转Word" FontSize="14"/>
                    <ListBoxItem Tag="PdfToImage" Content="PDF转图片" FontSize="14"/>
                    <ListBoxItem Tag="PdfToExcel" Content="PDF转Excel" FontSize="14"/>
                    <ListBoxItem Tag="PdfToPpt" Content="PDF转PPT" FontSize="14"/>
                    <ListBoxItem Tag="PdfToScannedPdf" Content="PDF转扫描件" FontSize="14"/>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- 置顶按钮 -->
        <ToggleButton x:Name="BtnTopmost" Content="📌 置顶"
                      DockPanel.Dock="Top" HorizontalAlignment="Right"
                      Margin="0,8,12,0" Padding="8,2"
                      Click="BtnTopmost_Click" Style="{StaticResource TopmostToggleButton}"/>

        <!-- 右侧内容区 -->
        <ContentControl x:Name="PageContent" Focusable="False" Margin="0,0,0,0"/>
    </DockPanel>
</Window>