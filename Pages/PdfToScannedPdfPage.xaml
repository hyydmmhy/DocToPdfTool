<UserControl x:Class="DocToPdfTool.Pages.PdfToScannedPdfPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnAddFiles" Content="添加PDF文件" Padding="16,6"
                    Click="BtnAddFiles_Click"/>
            <TextBlock x:Name="TxtDropHint" Text="或拖拽PDF文件到此处"
                       VerticalAlignment="Center" Foreground="#999999" FontSize="12"
                       Margin="12,0,0,0"/>
        </StackPanel>

        <!-- 文件列表 -->
        <ListView Grid.Row="1" x:Name="FileListView"
                  AllowDrop="True"
                  Drop="FileListView_Drop"
                  PreviewDragOver="FileListView_PreviewDragOver"
                  SizeChanged="FileListView_SizeChanged"
                  BorderBrush="#E0E0E0" BorderThickness="1"
                  Foreground="#1A1A1A"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock Text="{Binding FileName}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding FilePath}" Foreground="#666666"/>
                                </StackPanel>
                            </ToolTip>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="文件名" Width="180"
                                    DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="路径" Width="320"
                                    DisplayMemberBinding="{Binding FilePath}"/>
                    <GridViewColumn Header="操作" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="移除" Padding="8,2" FontSize="12"
                                        Tag="{Binding}"
                                        Click="BtnRemoveFile_Click"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 空状态提示 -->
        <Border Grid.Row="1" x:Name="EmptyOverlay" Background="White"
                IsHitTestVisible="False" Visibility="Visible">
            <TextBlock Text="拖拽PDF文件到此处，或点击上方「添加PDF文件」按钮"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#BBBBBB" FontSize="14"/>
        </Border>

        <!-- 说明区域 -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,10,0,6">
            <TextBlock Text="扫描件 PDF 每页为图片格式，不可编辑选取文字"
                       HorizontalAlignment="Center"
                       Foreground="#888888" FontSize="12"/>
        </Border>

        <!-- 转换按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,8">
            <Button x:Name="BtnConvert" Content="转换为扫描件"
                    Padding="24,8" Width="160"
                    Click="BtnConvert_Click"/>
        </StackPanel>

        <!-- 状态提示 -->
        <TextBlock Grid.Row="4" x:Name="TxtConversionStatus"
                   Foreground="#999999" FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0" Text=""/>
    </Grid>
</UserControl>